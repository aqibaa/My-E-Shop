generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String?
  role      String   @default("CUSTOMER")
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts Account[]
  orders   Order[]

  addresses Address[]
  reviews   Review[]
  wishlist  Product[] @relation("UserWishlist")
}



model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Product {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  description   String
  price         Decimal  @db.Decimal(10, 2)
  originalPrice Decimal? @db.Decimal(10, 2)
  stock         Int      @default(0)
  rating        Decimal  @default(0) @db.Decimal(3, 2)
  reviewCount   Int      @default(0)

  category String
  brand    String
  badge    String?

  image  String?
  images String[]

  colors   Json     @default("[]")
  features String[]
  sizes    String[]

  isFeatured Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  orderItems OrderItem[]
  
  reviews       Review[]
  wishlistedBy  User[]    @relation("UserWishlist")
}

model Review {
  id        String   @id @default(cuid())
  rating    Int      
  comment   String   @db.Text
  createdAt DateTime @default(now())
  
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
}


model Address {
  id         String   @id @default(cuid())
  firstName  String
  lastName   String
  email      String
  address    String
  city       String
  zip        String
  phone      String
  country    String   @default("USA")
  isDefault  Boolean  @default(false) 
  
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
}


model Coupon {
  id                 String   @id @default(cuid())
  code               String   @unique 
  discountPercentage Int      
  isActive           Boolean  @default(true)
  expiryDate         DateTime? 
  createdAt          DateTime @default(now())
}

model Order {
  id     String @id @default(cuid())
  userId String

  orderItems OrderItem[]

  shippingAddress String @db.Text

  paymentMethod String
  paymentResult String? @db.Text

  itemsPrice    Decimal @db.Decimal(12, 2)
  shippingPrice Decimal @db.Decimal(12, 2)
  taxPrice      Decimal @db.Decimal(12, 2)
  totalPrice    Decimal @db.Decimal(12, 2)

  status String @default("Pending")

  isPaid      Boolean   @default(false)
  paidAt      DateTime?
  isDelivered Boolean   @default(false)
  deliveredAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OrderItem {
  id String @id @default(cuid())

  name  String
  qty   Int
  image String
  price Decimal @db.Decimal(12, 2)

  color String?
  size  String?

  product   Product @relation(fields: [productId], references: [id])
  productId String

  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId String
}

model StoreSettings {
  id            String   @id @default("default")
  storeName     String   @default("My E-Shop")
  supportEmail  String   @default("support@example.com")
  taxRate       Decimal  @default(8.00) @db.Decimal(5, 2)
  shippingCost  Decimal  @default(15.00) @db.Decimal(10, 2)
  isMaintenance Boolean  @default(false)
  updatedAt     DateTime @updatedAt
}
